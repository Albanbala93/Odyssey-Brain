# Copy this file to apps/web/.env.local and fill in the values you have.
# Odyssey runs fully in local/offline mode with NO variables set: Phase 1
# (welcome → onboarding → mission → debrief) needs none of these.

# --- OpenAI (Phase 3: AI-generated coach conversation; Phase 4: voice) -----
# Server-side only. Never exposed to the browser. When unset, the coach API
# route (src/app/api/coach/turn/route.ts) automatically falls back to the
# deterministic local coach and labels responses "source": "local_fallback".
# Also enables server-side voice transcription (src/app/api/voice/transcribe
# /route.ts, Whisper) — when unset, VoiceRecorder falls back to the
# browser's Web Speech API where supported, then to the text field.
OPENAI_API_KEY=

# --- Supabase (Phase 2: authentication + persistent database) --------------
# Server-side only unless prefixed NEXT_PUBLIC_. When unset, the app uses
# LocalStorageUserStateRepository and guest-only auth.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: server-side only, never NEXT_PUBLIC_. Used for admin
# operations (account deletion, data export). Do not expose in any client bundle.
SUPABASE_SERVICE_ROLE_KEY=

# --- Analytics (Phase 6) ----------------------------------------------------
# Vendor-agnostic; the analytics abstraction (src/lib/analytics.ts) no-ops
# when unset.
NEXT_PUBLIC_ANALYTICS_WRITE_KEY=
